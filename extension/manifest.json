{
  "manifest_version": 3,
  "name": "AdGuard Hirdetésblokkoló",
  "version": "5.3.0.22",
  "description": "Páratlan adblock kiegészítő a reklámok és felugró ablakok ellen. Blokkolja a Facebook, YouTube és más webhelyek hirdetéseit.",
  "icons": {
    "16": "icons/icon.png",
    "48": "icons/icon.png",
    "128": "icons/icon.png"
  },
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "adblocker.html",
    "default_title": "AdGuard Hirdetésblokkoló",
    "default_icon": {
      "16": "icons/icon.png",
      "48": "icons/icon.png",
      "128": "icons/icon.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["inter.ttf"],
      "matches": ["https://*.netacad.com/*", "https://*.cisco.com/*"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["*://*.netacad.com/*", "*://*.cisco.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
